    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:description"/>
        <Literal xml:lang="es">La ontología de infraestructura pública describe todos los conceptos relacionados con las instalaciones públicas de un municipio.  Estas incluyen aparcamientos dentro y fuera de la vía pública, bibliotecas, centros de salud, centros sociales, juzgados, comisarías, entre otros.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:description"/>
        <Literal xml:lang="en">The public infrastructure ontology describes all concepts related to a municipality&apos;s public facilities. These include on-street and off-street parking, libraries, health centers, community centers, courthouses, police stations, among others.</Literal>
    </Annotation>
    <Annotation>
        <AnnotationProperty abbreviatedIRI="dcterms:license"/>
        <IRI>https://creativecommons.org/licenses/by/4.0/</IRI>
    </Annotation>
