        <AnnotationProperty abbreviatedIRI="rdfs:comment"/>
        <AbbreviatedIRI>gsp:Geometry</AbbreviatedIRI>
        <Literal xml:lang="es">La clase representa el tipo de geometría de nivel superior. Esta clase es equivalente a la clase UML GM_Object definida en la norma ISO 19107 y es la superclase de todos los tipos de geometría.</Literal>
    </AnnotationAssertion>
