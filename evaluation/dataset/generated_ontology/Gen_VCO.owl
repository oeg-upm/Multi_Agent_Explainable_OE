  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#RegulatedZone"/>
  <!-- Axiom: <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#zoneOfAuthorization'/> -->
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#belongsTo">
  Links a road segment to the road it belongs to.
  belongs to
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created object property: To model the relationship between road segments and roads.
