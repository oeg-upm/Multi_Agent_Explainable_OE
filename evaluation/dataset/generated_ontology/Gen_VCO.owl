  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Road"/>
  <!-- Axiom: <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasSegment'/> -->
</owl:ObjectProperty>

