<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">

  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Vehicle">
  A motorized vehicle that can be authorized for operation in regulated zones.
  Vehicle
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: Core concept from multiple competency questions involving vehicles.
    [Pitfall Resulotion Agent] Created class: Core concept from multiple competency questions involving vehicles.</vaem:rationale>
  <dc:source>(competency_question) Un vehículo tiene un titular/dueño
    (competency_question) ¿Qué vehículo es autorizado por una autorización determinada?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Person">
  An individual human being who can own vehicles or authorizations.
  Person
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To represent personal owners as per competency questions.
    [Pitfall Resulotion Agent] Created class: To represent personal owners as per competency questions.
    [Pitfall Resulotion Agent] Added disjoint axiom with Organization.: To fix P08 pitfall of missing disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) Un titular puede ser es una persona o una organización
    (pitfall) P08: Missing disjoint axioms between classes.</dc:source>
  <!-- Axiom: <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Organization'/> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Organization">
  A group or entity that can own vehicles or authorizations.
  Organization
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To represent organizational owners as per competency questions.
    [Pitfall Resulotion Agent] Created class: To represent organizational owners as per competency questions.
    [Pitfall Resulotion Agent] Added disjoint axiom with Person.: To fix P08 pitfall of missing disjoint axioms.</vaem:rationale>
  <dc:source>(competency_question) Un titular puede ser es una persona o una organización
    (pitfall) P08: Missing disjoint axioms between classes.</dc:source>
  <!-- Axiom: <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Person'/> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Owner">
  The owner or holder of a vehicle or authorization, which is either a person or an organization.
  Owner
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class as a union of Person and Organization: To model the concept of titular from competency questions.
    [Pitfall Resulotion Agent] Created class as a union of Person and Organization: To model the concept of titular from competency questions.
    [Pitfall Resulotion Agent] Added explicit equivalent class axiom.: To fix P01 pitfall of isolated class.</vaem:rationale>
  <dc:source>(competency_question) Un titular puede ser es una persona o una organización
    (pitfall) P01: Creating unconnected ontology elements.</dc:source>
  <!-- Axiom: <owl:equivalentClass><owl:Class><owl:unionOf rdf:parseType='Collection'><owl:Class rdf:about='http://www.semanticweb.org/myontology#Person'/><owl:Class rdf:about='http://www.semanticweb.org/myontology#Organization'/></owl:unionOf></owl:Class></owl:equivalentClass> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Authorization">
  A permit that authorizes a vehicle to operate in regulated zones or on road segments.
  Authorization
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: Central concept from questions about authorizations and their details.
    [Pitfall Resulotion Agent] Created class: Central concept from questions about authorizations and their details.</vaem:rationale>
  <dc:source>(competency_question) Una autorización tiene un titular
    (competency_question) ¿Qué vehículo es autorizado por una autorización determinada?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RegulatedZone">
  An area where vehicle access is regulated, such as for parking, low emissions, etc.
  Regulated Zone
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To model zones where authorizations are valid.
    [Pitfall Resulotion Agent] Created class: To model zones where authorizations are valid.</vaem:rationale>
  <dc:source>(competency_question) Una autorización autoriza en una zona regulada</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#ParkingZone">
  A regulated zone specifically for parking.
  Parking Zone
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created subclass of RegulatedZone: From competency question stating parking zones are regulated zones.
    [Pitfall Resulotion Agent] Created subclass of RegulatedZone: From competency question stating parking zones are regulated zones.
    [Pitfall Resulotion Agent] Added explicit subclass and disjoint axioms.: To fix P01 and P08 pitfalls.</vaem:rationale>
  <dc:source>(competency_question) Una zona de estacionamiento regulado es una zona regulada
    (pitfall) P01: Creating unconnected ontology elements. P08: Missing disjoint axioms.</dc:source>
    <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#RegulatedZone'/> 
  <!-- Axiom: <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#LowEmissionZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#EconomicInterestZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#HistoricalCaseZone'/> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#LowEmissionZone">
  A regulated zone with restrictions based on vehicle emissions.
  Low Emission Zone
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created subclass of RegulatedZone: From competency question stating low emission zones are regulated zones.
    [Pitfall Resulotion Agent] Created subclass of RegulatedZone: From competency question stating low emission zones are regulated zones.
    [Pitfall Resulotion Agent] Added explicit subclass and disjoint axioms.: To fix P01 and P08 pitfalls.</vaem:rationale>
  <dc:source>(competency_question) Una zona de bajas emisiones es una zona regulada
    (pitfall) P01: Creating unconnected ontology elements. P08: Missing disjoint axioms.</dc:source>
    <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#RegulatedZone'/>
  <!-- Axiom: <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#ParkingZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#EconomicInterestZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#HistoricalCaseZone'/> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#EconomicInterestZone">
  A regulated zone of economic interest.
  Economic Interest Zone
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created subclass of RegulatedZone: From competency question stating economic interest zones are regulated zones.
    [Pitfall Resulotion Agent] Created subclass of RegulatedZone: From competency question stating economic interest zones are regulated zones.
    [Pitfall Resulotion Agent] Added explicit subclass and disjoint axioms.: To fix P01 and P08 pitfalls.</vaem:rationale>
  <dc:source>(competency_question) Una zona de interés económico es una zona regulada
    (pitfall) P01: Creating unconnected ontology elements. P08: Missing disjoint axioms.</dc:source>
    <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#RegulatedZone'/>
    <!-- Axiom: <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#ParkingZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#LowEmissionZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#HistoricalCaseZone'/> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#HistoricalCaseZone">
  A regulated zone based on historical cases.
  Historical Case Zone
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created subclass of RegulatedZone: From competency question stating historical cases are regulated zones.
    [Pitfall Resulotion Agent] Created subclass of RegulatedZone: From competency question stating historical cases are regulated zones.
    [Pitfall Resulotion Agent] Added explicit subclass and disjoint axioms.: To fix P01 and P08 pitfalls.</vaem:rationale>
  <dc:source>(competency_question) Un caso histórico es una zona regulada
    (pitfall) P01: Creating unconnected ontology elements. P08: Missing disjoint axioms.</dc:source>
    <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#RegulatedZone'/> 
  <!-- Axiom: <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#ParkingZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#LowEmissionZone'/> <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#EconomicInterestZone'/> -->
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RoadSegment">
  A specific segment of a road where authorizations may be valid.
  Road Segment
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To model road segments where authorizations are valid.
    [Pitfall Resulotion Agent] Created class: To model road segments where authorizations are valid.</vaem:rationale>
  <dc:source>(competency_question) ¿En que tramo de vía es válida una autorización?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Road">
  A road or highway that contains segments.
  Road
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To model roads as containers for road segments.
    [Pitfall Resulotion Agent] Created class: To model roads as containers for road segments.</vaem:rationale>
  <dc:source>(competency_question) Una autorización autoriza a un vehículo en un tramo perteneciente a una via</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#EnvironmentalBadge">
  A badge indicating the environmental classification of a vehicle.
  Environmental Badge
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To model environmental badges from questions about vehicle authorizations.
    [Pitfall Resulotion Agent] Created class: To model environmental badges from questions about vehicle authorizations.</vaem:rationale>
  <dc:source>(competency_question) ¿Qué distintivo ambiental tiene un vehículo autorizado?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#AuthorizationType">
  A category or type of authorization, such as commercial or annual.
  Authorization Type
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To model different types of authorizations from competency questions.
    [Pitfall Resulotion Agent] Created class: To model different types of authorizations from competency questions.</vaem:rationale>
  <dc:source>(competency_question) ¿Qué tipos de autorizaciones existen?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VehicleType">
  A category of vehicle, such as commercial or electric.
  Vehicle Type
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created class: To model vehicle types for queries about access and authorizations.
    [Pitfall Resulotion Agent] Created class: To model vehicle types for queries about access and authorizations.</vaem:rationale>
  <dc:source>(competency_question) ¿Qué tipos de vehículo con un determinado distintivo ambiental están autorizados en una zona regulada?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVehicleOwner">
  Specifies the owner of a vehicle.
  has vehicle owner
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created object property: To link vehicles to their owners as per competency questions.
    [Pitfall Resulotion Agent] Created object property: To link vehicles to their owners as per competency questions.
    [Pitfall Resulotion Agent] Added inverse relationship.: To fix P19 pitfall of missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) Un vehículo tiene un titular/dueño
    (pitfall) P19: Missing inverse relationships.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Vehicle"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Owner"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <!-- Axiom: <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#ownerOfVehicle'/> -->
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasAuthorizationOwner">
  Specifies the owner of an authorization.
  has authorization owner
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created object property: To link authorizations to their owners as per competency questions.
    [Pitfall Resulotion Agent] Created object property: To link authorizations to their owners as per competency questions.
    [Pitfall Resulotion Agent] Added inverse relationship.: To fix P19 pitfall of missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) Una autorización tiene un titular
    (pitfall) P19: Missing inverse relationships.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Authorization"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Owner"/>
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <!-- Axiom: <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#ownerOfAuthorization'/> -->
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#authorizes">
  Links an authorization to the vehicle it authorizes.
  authorizes
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created object property: To model which vehicle is authorized by an authorization.
    [Pitfall Resulotion Agent] Created object property: To model which vehicle is authorized by an authorization.
    [Pitfall Resulotion Agent] Added inverse relationship.: To fix P19 pitfall of missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) ¿Qué vehículo es autorizado por una autorización determinada?
    (pitfall) P19: Missing inverse relationships.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Authorization"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Vehicle"/>
  <!-- Axiom: <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isAuthorizedBy'/> -->
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#validOn">
  Specifies the road segment where an authorization is valid.
  valid on
  <vaem:rationale>[Ontology Generation Agent] unknown: [Ontology Generation Agent] Created object property: To indicate on which road segment an authorization is valid.
    [Pitfall Resulotion Agent] Created object property: To indicate on which road segment an authorization is valid.
    [Pitfall Resulotion Agent] Added inverse relationship.: To fix P19 pitfall of missing inverse relationships.</vaem:rationale>
  <dc:source>(competency_question) ¿En que tramo de vía es válida una autorización?
