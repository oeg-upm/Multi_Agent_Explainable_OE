   "outputs": [],
   "source": [
    "res = []"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "038c898a-4209-403b-ba2d-c3ab9d35dbd6",
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(\"awo_CQs_onto.json\", \"rb\") as f:\n",
    "    data = json.load(f)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "0dc08fc6-c26a-4e61-9b75-ec3752cbc940",
   "metadata": {},
   "outputs": [],
   "source": [
    "for key, value in data.items():\n",
    "    res.append({\"id\": key, \"value\": value})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "de03cdb2-09fe-4a66-abfa-5dc7cdef1962",
   "metadata": {},
   "outputs": [],
   "source": [
    "with open(\"awo_cqs.json\", \"w\") as f:\n",
    "    json.dump(res, f)"
   ]
  },
