<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A beverage produced by fermenting grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ2
    (competency_question) CQ6
    (competency_question) CQ7
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A wine variety characterized by red or purple hues.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#WhiteWine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A wine variety characterized by pale yellow or greenish hues.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A wine originating from the Bordeaux region of France.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux Wine</rdfs:label>
  <dc:source>(competency_question) CQ2
    (competency_question) CQnew1</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">The calendar year in which the grapes for a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
  <dc:source>(competency_question) CQ6
    (competency_question) CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  <rdfs:comment xml:lang="en">The fruit species used as the primary ingredient in winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape</rdfs:label>
  <dc:source>(competency_question) CQ7
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A qualitative or sensory attribute used to describe a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The perceived weight, texture, and mouthfeel of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ6</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The complex aroma profile of a wine, often developing with age.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ6</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Color">
  <rdfs:comment xml:lang="en">The visual hue or shade of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Color</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Red">
  <rdfs:comment xml:lang="en">A color category indicating red or purple wine hues.</rdfs:comment>
  <rdfs:label xml:lang="en">Red</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Color'/>
  <owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#White'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#White">
  <rdfs:comment xml:lang="en">A color category indicating pale yellow or greenish wine hues.</rdfs:comment>
  <rdfs:label xml:lang="en">White</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Color'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">A geographical area recognized for wine production.</rdfs:comment>
  <rdfs:label xml:lang="en">Region</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Links a wine to its qualitative sensory attributes.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Links a wine to its visual color category.</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Color"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Links a wine to its mouthfeel and weight characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Links a wine to its aroma profile characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <rdfs:subPropertyOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">Links a wine to the year its grapes were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage year</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrape">
  <rdfs:comment xml:lang="en">Links a wine to the grape variety used in its production.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape</rdfs:label>
  <dc:source>(competency_question) CQnew1</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGoodVintage">
  <rdfs:comment xml:lang="en">Links a grape variety to years that yielded high-quality harvests.</rdfs:comment>
  <rdfs:label xml:lang="en">has good vintage</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Grape"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isProducedIn">
  <rdfs:comment xml:lang="en">Links a wine to its geographical region of origin.</rdfs:comment>
  <rdfs:label xml:lang="en">is produced in</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Region"/>
</owl:ObjectProperty>

</rdf:RDF>