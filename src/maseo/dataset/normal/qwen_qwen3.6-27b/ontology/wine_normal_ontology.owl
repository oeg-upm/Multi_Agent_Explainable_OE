<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A fermented alcoholic beverage made from grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created root class for all wine types and instances.: Required by all competency questions as the central domain concept.</vaem:rationale>
  <dc:source>(competency_question) CQ1, CQ2, CQ6, CQ7, CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A wine that exhibits a red color profile.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Wine.: Needed to answer CQ2 regarding wine color classification.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A wine that exhibits a white or pale yellow color profile.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Wine and made disjoint with RedWine.: Needed to answer CQ2 regarding wine color classification.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A wine originating from the Bordeaux region of France.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Wine.: Explicitly mentioned in CQ2 and CQnew1.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandel">
  <rdfs:comment xml:lang="en">A Zinfandel wine originating from the Napa Valley region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Wine.: Explicitly mentioned in CQ7.</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Characteristic">
  <rdfs:comment xml:lang="en">A distinguishing sensory or physical attribute of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Characteristic</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as superclass for wine attributes.: Required by CQ1 to model wine characteristics.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The complex aroma of a wine, typically developed through aging.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Characteristic.: Explicitly mentioned in CQ6.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Characteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The weight, texture, or fullness of a wine on the palate.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Characteristic.: Explicitly mentioned in CQ6.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Characteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Color">
  <rdfs:comment xml:lang="en">The visual hue or shade of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Color</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Characteristic.: Needed to model wine color for CQ2.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Characteristic"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Red">
  <rdfs:comment xml:lang="en">A red color characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">Red</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Color.: Needed to answer CQ2.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Color"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#White">
  <rdfs:comment xml:lang="en">A white or pale color characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">White</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subclass of Color.: Needed to answer CQ2.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Color"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GrapeVarietal">
  <rdfs:comment xml:lang="en">A specific cultivated variety of grape used in winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape Varietal</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model grape types.: Required by CQnew1.</vaem:rationale>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">The calendar year in which the grapes for a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model harvest years.: Required by CQ6 and CQ7.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#QualityRating">
  <rdfs:comment xml:lang="en">An assessment or score indicating the quality of a wine or vintage.</rdfs:comment>
  <rdfs:label xml:lang="en">Quality Rating</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created to model wine quality assessments.: Required by CQ7 to identify 'good vintages'.</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Associates a wine with one or more of its sensory or physical characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has Characteristic</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as object property linking Wine to Characteristic.: Directly answers CQ1.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Characteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Associates a wine with its specific bouquet characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has Bouquet</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subproperty of hasCharacteristic.: Explicitly mentioned in CQ6.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Associates a wine with its specific body characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has Body</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as subproperty of hasCharacteristic.: Explicitly mentioned in CQ6.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/myontology#hasCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Associates a wine with its visual color.</rdfs:comment>
  <rdfs:label xml:lang="en">has Color</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as object property linking Wine to Color.: Needed to answer CQ2.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Color"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrapeVarietal">
  <rdfs:comment xml:lang="en">Associates a wine with the grape varieties used to produce it.</rdfs:comment>
  <rdfs:label xml:lang="en">has Grape Varietal</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as object property linking Wine to GrapeVarietal.: Directly answers CQnew1.</vaem:rationale>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GrapeVarietal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">Associates a wine with the year its grapes were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">has Vintage Year</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as object property linking Wine to VintageYear.: Required by CQ6 and CQ7.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasQualityRating">
  <rdfs:comment xml:lang="en">Associates a wine with an assessment of its quality.</rdfs:comment>
  <rdfs:label xml:lang="en">has Quality Rating</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created as object property linking Wine to QualityRating.: Required by CQ7 to identify good vintages.</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#QualityRating"/>
</owl:ObjectProperty>

</rdf:RDF>