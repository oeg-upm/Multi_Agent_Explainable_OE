<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Thing">
  <rdfs:comment xml:lang="en">The top-level class representing all entities in the ontology.</rdfs:comment>
  <rdfs:label xml:lang="en">Thing</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Declared as owl:Class and added annotations: Fixes oops:undeclaredClass and oops:annotation pitfalls.</vaem:rationale>
  <dc:source>(pitfall) oops:undeclaredClass
    (pitfall) oops:annotation</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A fermented beverage typically made from grapes, characterized by various sensory and qualitative attributes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ2
    (competency_question) CQ6
    (competency_question) CQ7
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">A sensory or qualitative attribute used to describe or evaluate a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Color">
  <rdfs:comment xml:lang="en">The visual hue or appearance of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Color</rdfs:label>
  <dc:source>(competency_question) CQ2</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The perceived weight, texture, and mouthfeel of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The complex aroma profile of a wine, often developing with age or fermentation.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <dc:source>(competency_question) CQ6</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Region">
  <rdfs:comment xml:lang="en">A geographical area known for wine production, influencing the style and characteristics of the wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Region</rdfs:label>
  <dc:source>(competency_question) CQ7
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GrapeVariety">
  <rdfs:comment xml:lang="en">A specific cultivar of grape used in the production of wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape Variety</rdfs:label>
  <dc:source>(competency_question) CQnew1
    (competency_question) CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">The calendar year in which the grapes for a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
  <dc:source>(competency_question) CQ6
    (competency_question) CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A type of wine produced from dark-colored grape varieties with extended skin contact.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axiom with WhiteWine: Fixes oops:disjoint pitfall by ensuring mutually exclusive wine types.</vaem:rationale>
  <dc:source>(competency_question) CQ2
    (pitfall) oops:disjoint</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WhiteWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A type of wine produced with minimal skin contact, typically from green or yellow grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added disjoint axiom with RedWine: Fixes oops:disjoint pitfall by ensuring mutually exclusive wine types.</vaem:rationale>
  <dc:source>(competency_question) CQ2
    (pitfall) oops:disjoint</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A major wine-producing region in France, often used to refer to wines originating from this area.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <dc:source>(competency_question) CQ2
    (competency_question) CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Napa">
  <rdfs:comment xml:lang="en">A prominent wine region located in California, United States.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Zinfandel">
  <rdfs:comment xml:lang="en">A black-skinned grape variety widely cultivated in California and other warm climates.</rdfs:comment>
  <rdfs:label xml:lang="en">Zinfandel</rdfs:label>
  <dc:source>(competency_question) CQ7</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Links a wine to its sensory or qualitative attributes.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isCharacteristicOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ1
    (competency_question) CQ6
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isCharacteristicOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCharacteristicOf">
  <rdfs:comment xml:lang="en">Inverse of hasCharacteristic. Links a wine characteristic to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is characteristic of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasCharacteristic"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Links a wine to its visual color classification.</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isColorOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ2
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Color"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isColorOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isColorOf">
  <rdfs:comment xml:lang="en">Inverse of hasColor.</rdfs:comment>
  <rdfs:label xml:lang="en">is color of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Color"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasColor"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Links a wine to its perceived weight and texture in the mouth.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isBodyOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ6
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isBodyOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isBodyOf">
  <rdfs:comment xml:lang="en">Inverse of hasBody.</rdfs:comment>
  <rdfs:label xml:lang="en">is body of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasBody"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Links a wine to its complex aroma profile.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isBouquetOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ6
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isBouquetOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isBouquetOf">
  <rdfs:comment xml:lang="en">Inverse of hasBouquet.</rdfs:comment>
  <rdfs:label xml:lang="en">is bouquet of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasBouquet"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRegion">
  <rdfs:comment xml:lang="en">Links a wine to its geographical area of origin.</rdfs:comment>
  <rdfs:label xml:lang="en">has region</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isRegionOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ7
    (competency_question) CQnew1
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Region"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isRegionOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isRegionOf">
  <rdfs:comment xml:lang="en">Inverse of hasRegion.</rdfs:comment>
  <rdfs:label xml:lang="en">is region of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Region"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasRegion"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrapeVariety">
  <rdfs:comment xml:lang="en">Links a wine to the specific grape cultivar used in its production.</rdfs:comment>
  <rdfs:label xml:lang="en">has grape variety</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGrapeVarietyOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQnew1
    (competency_question) CQ7
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GrapeVariety"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGrapeVarietyOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGrapeVarietyOf">
  <rdfs:comment xml:lang="en">Inverse of hasGrapeVariety.</rdfs:comment>
  <rdfs:label xml:lang="en">is grape variety of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GrapeVariety"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGrapeVariety"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">Links a wine to the year its grapes were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage year</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isVintageYearOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ6
    (competency_question) CQ7
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isVintageYearOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVintageYearOf">
  <rdfs:comment xml:lang="en">Inverse of hasVintageYear.</rdfs:comment>
  <rdfs:label xml:lang="en">is vintage year of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasVintageYear"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGoodVintage">
  <rdfs:comment xml:lang="en">Links a wine to years historically considered exceptional for that specific wine or region.</rdfs:comment>
  <rdfs:label xml:lang="en">has good vintage</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Added inverse property isGoodVintageOf: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(competency_question) CQ7
    (pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGoodVintageOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGoodVintageOf">
  <rdfs:comment xml:lang="en">Inverse of hasGoodVintage.</rdfs:comment>
  <rdfs:label xml:lang="en">is good vintage of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property: Fixes oops:inverse pitfall.</vaem:rationale>
  <dc:source>(pitfall) oops:inverse</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGoodVintage"/>
</owl:ObjectProperty>

</rdf:RDF>