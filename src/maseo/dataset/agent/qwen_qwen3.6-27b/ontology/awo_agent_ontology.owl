<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Animal">
  <rdfs:comment xml:lang="en">An organism belonging to the kingdom Animalia.</rdfs:comment>
  <rdfs:label xml:lang="en">Animal</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Animal: Core entity required to answer CQ1, CQ2, CQ3, CQ4, CQ6, CQ7, CQ14
    [Pitfall Resolution Agent] Added disjoint axiom with Plant: Resolves OOPS pitfall: lack of disjoint axioms between biologically distinct kingdoms.</vaem:rationale>
  <dc:source>(competency_question) CQ1, CQ2, CQ3, CQ4, CQ6, CQ7, CQ14
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Plant">
  <rdfs:comment xml:lang="en">An organism belonging to the kingdom Plantae.</rdfs:comment>
  <rdfs:label xml:lang="en">Plant</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Plant: Core entity required to answer CQ3, CQ4, CQ6
    [Pitfall Resolution Agent] Added disjoint axiom with Animal: Resolves OOPS pitfall: lack of disjoint axioms between biologically distinct kingdoms.</vaem:rationale>
  <dc:source>(competency_question) CQ3, CQ4, CQ6
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Herbivore">
  <rdfs:comment xml:lang="en">An animal that primarily feeds on plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Herbivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Herbivore as subclass of Animal: Required to answer CQ2 and CQ3
    [Pitfall Resolution Agent] Added disjoint axioms with Carnivore and Omnivore: Resolves OOPS pitfall: lack of disjoint axioms between mutually exclusive dietary categories.</vaem:rationale>
  <dc:source>(competency_question) CQ2, CQ3
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Carnivore"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Omnivore"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Carnivore">
  <rdfs:comment xml:lang="en">An animal that primarily feeds on other animals. Some carnivores may occasionally consume plants or plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Carnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Carnivore as subclass of Animal: Required to answer CQ14
    [Pitfall Resolution Agent] Added disjoint axioms with Herbivore and Omnivore: Resolves OOPS pitfall: lack of disjoint axioms between mutually exclusive dietary categories.</vaem:rationale>
  <dc:source>(competency_question) CQ14
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Herbivore"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Omnivore"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Omnivore">
  <rdfs:comment xml:lang="en">An animal that feeds on both animals and plants/plant parts.</rdfs:comment>
  <rdfs:label xml:lang="en">Omnivore</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Omnivore as subclass of Animal: Required to answer CQ3
    [Pitfall Resolution Agent] Added disjoint axioms with Herbivore and Carnivore: Resolves OOPS pitfall: lack of disjoint axioms between mutually exclusive dietary categories.</vaem:rationale>
  <dc:source>(competency_question) CQ3
    (pitfall) The ontology lacks disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Herbivore"/><owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#Carnivore"/>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEatenBy">
  <rdfs:comment xml:lang="en">Inverse of eats. Relates an animal to the animal that consumes it.</rdfs:comment>
  <rdfs:label xml:lang="en">is eaten by</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for eats: Resolves OOPS pitfall: missing inverse relationships.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#eats"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEatenByPlant">
  <rdfs:comment xml:lang="en">Inverse of eatsPlant. Relates a plant to the animal that consumes it.</rdfs:comment>
  <rdfs:label xml:lang="en">is eaten by plant</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for eatsPlant: Resolves OOPS pitfall: missing inverse relationships.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#eatsPlant"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEatenByPlantPart">
  <rdfs:comment xml:lang="en">Inverse of eatsPlantPart. Relates a plant part to the animal that consumes it.</rdfs:comment>
  <rdfs:label xml:lang="en">is eaten by plant part</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for eatsPlantPart: Resolves OOPS pitfall: missing inverse relationships.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#eatsPlantPart"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isEatenByAnimal">
  <rdfs:comment xml:lang="en">Inverse of eatsAnimal. Relates an animal to the plant that consumes it.</rdfs:comment>
  <rdfs:label xml:lang="en">is eaten by animal</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for eatsAnimal: Resolves OOPS pitfall: missing inverse relationships.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Animal"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#eatsAnimal"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isPartOfPlant">
  <rdfs:comment xml:lang="en">Inverse of hasPlantPart. Relates a plant part to the plant it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is part of plant</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property for hasPlantPart: Resolves OOPS pitfall: missing inverse relationships.</vaem:rationale>
  <dc:source>(pitfall) This pitfall appears when any relationship does not have an inverse relationship defined.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#PlantPart"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Plant"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasPlantPart"/>
</owl:ObjectProperty>

</rdf:RDF>