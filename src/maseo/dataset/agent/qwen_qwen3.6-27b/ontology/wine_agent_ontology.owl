<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  <rdfs:comment xml:lang="en">A fermented alcoholic beverage made from grapes.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Wine: Core concept required by all competency questions.
    [Pitfall Resolution Agent] Created class Wine: Core concept required by all competency questions.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ2: Is Bordeaux a red or white wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineCharacteristic">
  <rdfs:comment xml:lang="en">An attribute or property that describes a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Characteristic</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WineCharacteristic: To categorize attributes like bouquet and body as requested in CQ1 and CQ6.
    [Pitfall Resolution Agent] Created class WineCharacteristic: To categorize attributes like bouquet and body as requested in CQ1 and CQ6.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bouquet">
  <rdfs:comment xml:lang="en">The aroma of a wine, particularly after aging.</rdfs:comment>
  <rdfs:label xml:lang="en">Bouquet</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Bouquet: Specific characteristic mentioned in CQ6.
    [Pitfall Resolution Agent] Created class Bouquet: Specific characteristic mentioned in CQ6.
    [Pitfall Resolution Agent] Added disjointWith axiom with Body: Resolve OOPS pitfall: lack of disjoint axioms between mutually exclusive classes.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (pitfall) Lack of disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#Body'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Body">
  <rdfs:comment xml:lang="en">The weight or fullness of a wine on the palate.</rdfs:comment>
  <rdfs:label xml:lang="en">Body</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Body: Specific characteristic mentioned in CQ6.
    [Pitfall Resolution Agent] Created class Body: Specific characteristic mentioned in CQ6.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#WineCharacteristic'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineColor">
  <rdfs:comment xml:lang="en">The visual color category of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">Wine Color</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WineColor: To model red and white wine distinctions from CQ2.
    [Pitfall Resolution Agent] Created class WineColor: To model red and white wine distinctions from CQ2.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  <rdfs:comment xml:lang="en">A wine made from dark-colored grape varieties.</rdfs:comment>
  <rdfs:label xml:lang="en">Red Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class RedWine: Subclass of Wine to answer CQ2.
    [Pitfall Resolution Agent] Created class RedWine: Subclass of Wine to answer CQ2.
    [Pitfall Resolution Agent] Added disjointWith axiom with WhiteWine: Resolve OOPS pitfall: lack of disjoint axioms between mutually exclusive classes.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (pitfall) Lack of disjoint axioms between classes or between properties that should be defined as disjoint.</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
<owl:disjointWith rdf:resource='http://www.semanticweb.org/myontology#WhiteWine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  <rdfs:comment xml:lang="en">A wine made from white or light-colored grape varieties.</rdfs:comment>
  <rdfs:label xml:lang="en">White Wine</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class WhiteWine: Subclass of Wine to answer CQ2.
    [Pitfall Resolution Agent] Created class WhiteWine: Subclass of Wine to answer CQ2.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Bordeaux">
  <rdfs:comment xml:lang="en">A wine originating from the Bordeaux region of France.</rdfs:comment>
  <rdfs:label xml:lang="en">Bordeaux</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class Bordeaux: Specific wine type mentioned in CQ2 and CQnew1.
    [Pitfall Resolution Agent] Created class Bordeaux: Specific wine type mentioned in CQ2 and CQnew1.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#NapaZinfandel">
  <rdfs:comment xml:lang="en">A Zinfandel wine produced in the Napa Valley region.</rdfs:comment>
  <rdfs:label xml:lang="en">Napa Zinfandel</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class NapaZinfandel: Specific wine type mentioned in CQ7.
    [Pitfall Resolution Agent] Created class NapaZinfandel: Specific wine type mentioned in CQ7.</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
  <rdfs:subClassOf rdf:resource='http://www.semanticweb.org/myontology#Wine'/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#GrapeVariety">
  <rdfs:comment xml:lang="en">A specific cultivar of grape used in winemaking.</rdfs:comment>
  <rdfs:label xml:lang="en">Grape Variety</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class GrapeVariety: To model grape types used in wine production as per CQnew1.
    [Pitfall Resolution Agent] Created class GrapeVariety: To model grape types used in wine production as per CQnew1.</vaem:rationale>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#VintageYear">
  <rdfs:comment xml:lang="en">The year in which the grapes for a wine were harvested.</rdfs:comment>
  <rdfs:label xml:lang="en">Vintage Year</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created class VintageYear: To model temporal aspects of wine production for CQ6 and CQ7.
    [Pitfall Resolution Agent] Created class VintageYear: To model temporal aspects of wine production for CQ6 and CQ7.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasCharacteristic">
  <rdfs:comment xml:lang="en">Associates a wine with its descriptive characteristics.</rdfs:comment>
  <rdfs:label xml:lang="en">has characteristic</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasCharacteristic: To link wines to their characteristics as asked in CQ1.
    [Pitfall Resolution Agent] Created property hasCharacteristic: To link wines to their characteristics as asked in CQ1.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isCharacteristicOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ1: Which wine characteristics should I consider when choosing a wine?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isCharacteristicOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  <rdfs:comment xml:lang="en">Specifies the color category of a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has color</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasColor: To determine if a wine is red or white as per CQ2.
    [Pitfall Resolution Agent] Created property hasColor: To determine if a wine is red or white as per CQ2.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isColorOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ2: Is Bordeaux a red or white wine?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#WineColor"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isColorOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  <rdfs:comment xml:lang="en">Links a wine to its bouquet characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has bouquet</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasBouquet: Specific characteristic property for CQ6.
    [Pitfall Resolution Agent] Created property hasBouquet: Specific characteristic property for CQ6.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isBouquetOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isBouquetOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  <rdfs:comment xml:lang="en">Links a wine to its body characteristic.</rdfs:comment>
  <rdfs:label xml:lang="en">has body</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasBody: Specific characteristic property for CQ6.
    [Pitfall Resolution Agent] Created property hasBody: Specific characteristic property for CQ6.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isBodyOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isBodyOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#madeFromGrape">
  <rdfs:comment xml:lang="en">Indicates the grape variety used to produce a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">made from grape</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property madeFromGrape: To link wines to their grape varieties as per CQnew1.
    [Pitfall Resolution Agent] Created property madeFromGrape: To link wines to their grape varieties as per CQnew1.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isUsedInWine: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQnew1: What grapes are used to make Bordeaux wine?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#GrapeVariety"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isUsedInWine'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  <rdfs:comment xml:lang="en">Specifies the vintage year associated with a wine.</rdfs:comment>
  <rdfs:label xml:lang="en">has vintage year</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasVintageYear: To model vintage years for CQ6 and CQ7.
    [Pitfall Resolution Agent] Created property hasVintageYear: To model vintage years for CQ6 and CQ7.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isVintageYearOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ6: Does a bouquet or body of a specific wine change with vintage year?
    (competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isVintageYearOf'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGoodVintage">
  <rdfs:comment xml:lang="en">Links a wine type to its historically good vintage years.</rdfs:comment>
  <rdfs:label xml:lang="en">has good vintage</rdfs:label>
  <vaem:rationale>[Ontology Generation Agent] Created property hasGoodVintage: To model good vintage years for specific wines as per CQ7.
    [Pitfall Resolution Agent] Created property hasGoodVintage: To model good vintage years for specific wines as per CQ7.
    [Pitfall Resolution Agent] Added inverseOf axiom linking to isGoodVintageFor: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(competency_question) CQ7: What were good vintages for Napa Zinfandel?
    (pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#isGoodVintageFor'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isCharacteristicOf">
  <rdfs:comment xml:lang="en">Inverse of hasCharacteristic. Links a characteristic to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is characteristic of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isCharacteristicOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineCharacteristic"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasCharacteristic'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isColorOf">
  <rdfs:comment xml:lang="en">Inverse of hasColor. Links a color to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is color of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isColorOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#WineColor"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasColor'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isBouquetOf">
  <rdfs:comment xml:lang="en">Inverse of hasBouquet. Links a bouquet to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is bouquet of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isBouquetOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Bouquet"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasBouquet'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isBodyOf">
  <rdfs:comment xml:lang="en">Inverse of hasBody. Links a body characteristic to the wine it describes.</rdfs:comment>
  <rdfs:label xml:lang="en">is body of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isBodyOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#Body"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasBody'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isUsedInWine">
  <rdfs:comment xml:lang="en">Inverse of madeFromGrape. Links a grape variety to the wines it is used in.</rdfs:comment>
  <rdfs:label xml:lang="en">is used in wine</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isUsedInWine: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#GrapeVariety"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#madeFromGrape'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isVintageYearOf">
  <rdfs:comment xml:lang="en">Inverse of hasVintageYear. Links a vintage year to the wine it belongs to.</rdfs:comment>
  <rdfs:label xml:lang="en">is vintage year of</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isVintageYearOf: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasVintageYear'/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGoodVintageFor">
  <rdfs:comment xml:lang="en">Inverse of hasGoodVintage. Links a good vintage year to the wine type it applies to.</rdfs:comment>
  <rdfs:label xml:lang="en">is good vintage for</rdfs:label>
  <vaem:rationale>[Pitfall Resolution Agent] Created inverse property isGoodVintageFor: Resolve OOPS pitfall: missing inverse relationships for object properties.</vaem:rationale>
  <dc:source>(pitfall) Missing inverse relationship for object properties.</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#VintageYear"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource='http://www.semanticweb.org/myontology#hasGoodVintage'/>
</owl:ObjectProperty>

</rdf:RDF>