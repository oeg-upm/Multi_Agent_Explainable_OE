<?xml version="1.0"?>
<rdf:RDF xml:base="http://www.semanticweb.org/myontology#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xmlns:vaem="http://www.linkedmodel.org/schema/vaem#">
 
  <owl:Ontology rdf:about="http://www.semanticweb.org/myontology#"/>

  <!-- owl:Class declarations -->

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Wine">
  A wine from a specific vintage.
  Wine
  <vaem:rationale>[Ontology Generation Agent] Created wine class: Central concept for all competency questions.
    [Pitfall Resolution Agent] Created wine class: Central concept for all competency questions.
    [Pitfall Resolution Agent] No change to Wine class: No pitfalls directly affecting Wine class.</vaem:rationale>
  <dc:source>(competency_question) CQ1, CQ2, CQ6, CQ7, CQnew1</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#RedWine">
  A wine that is red in color.
  Red Wine
  <vaem:rationale>[Ontology Generation Agent] Created RedWine class: To distinguish red wines from white wines as per CQ2.
    [Pitfall Resolution Agent] Created RedWine class: To distinguish red wines from white wines as per CQ2.
    [Pitfall Resolution Agent] Fixed subClassOf to point to local Wine class instead of external URI: Addresses pitfall P13: external class not declared; also P01 not applicable.</vaem:rationale>
  <dc:source>(competency_question) CQ2
    (pitfall) P13</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#WhiteWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WhiteWine">
  A wine that is white in color.
  White Wine
  <vaem:rationale>[Ontology Generation Agent] Created WhiteWine class: To distinguish white wines from red wines as per CQ2.
    [Pitfall Resolution Agent] Created WhiteWine class: To distinguish white wines from red wines as per CQ2.
    [Pitfall Resolution Agent] Fixed subClassOf to point to local Wine class; added disjoint with RedWine: Addresses P13 and P04 (disjointness).</vaem:rationale>
  <dc:source>(competency_question) CQ2
    (pitfall) P13
    (pitfall) P04</dc:source>
  <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/myontology#Wine"/>
<owl:disjointWith rdf:resource="http://www.semanticweb.org/myontology#RedWine"/>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#WineRegion">
  A geographic region where wine is produced.
  Wine Region
  <vaem:rationale>[Ontology Generation Agent] Created WineRegion class: Needed to associate wines with regions like Bordeaux and Napa (CQ2, CQ7).
    [Pitfall Resolution Agent] Created WineRegion class: Needed to associate wines with regions like Bordeaux and Napa (CQ2, CQ7).</vaem:rationale>
  <dc:source>(competency_question) CQ2, CQ7</dc:source>
</owl:Class>

<owl:Class rdf:about="http://www.semanticweb.org/myontology#Grape">
  A type of grape used in winemaking.
  Grape
  <vaem:rationale>[Ontology Generation Agent] Created Grape class: Needed to model grapes used in wines, e.g., for CQnew1 (Bordeaux grapes) and CQ7 (Zinfandel).
    [Pitfall Resolution Agent] Created Grape class: Needed to model grapes used in wines, e.g., for CQnew1 (Bordeaux grapes) and CQ7 (Zinfandel).</vaem:rationale>
  <dc:source>(competency_question) CQnew1, CQ7</dc:source>
</owl:Class>

  <!-- owl:ObjectProperty declarations -->

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasRegion">
  Associates a wine with the region where it was produced.
  has region
  <vaem:rationale>[Ontology Generation Agent] Created hasRegion property: To link wines to their production regions, key for CQ2 (Bordeaux) and CQ7 (Napa).
    [Pitfall Resolution Agent] Created hasRegion property: To link wines to their production regions, key for CQ2 (Bordeaux) and CQ7 (Napa).
    [Pitfall Resolution Agent] Added inverse property isRegionOf: Addresses pitfall P05: missing inverse relationship.</vaem:rationale>
  <dc:source>(competency_question) CQ2, CQ7
    (pitfall) P05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#WineRegion"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isRegionOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#hasGrape">
  Associates a wine with the grape variety used to make it.
  has grape
  <vaem:rationale>[Ontology Generation Agent] Created hasGrape property: To model grape varieties used in wines, essential for CQnew1 (Bordeaux grapes) and CQ7 (Zinfandel).
    [Pitfall Resolution Agent] Created hasGrape property: To model grape varieties used in wines, essential for CQnew1 (Bordeaux grapes) and CQ7 (Zinfandel).
    [Pitfall Resolution Agent] Added inverse property isGrapeOf: Addresses pitfall P05: missing inverse relationship.</vaem:rationale>
  <dc:source>(competency_question) CQnew1, CQ7
    (pitfall) P05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Grape"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#isGrapeOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isRegionOf">
  Indicates that a wine region is the origin of a wine. Inverse of hasRegion.
  is region of
  <vaem:rationale>[Pitfall Resolution Agent] Created isRegionOf property as inverse of hasRegion: Addresses pitfall P05: missing inverse relationship for hasRegion.</vaem:rationale>
  <dc:source>(pitfall) P05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#WineRegion"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="http://www.semanticweb.org/myontology#isGrapeOf">
  Indicates that a grape is used in a wine. Inverse of hasGrape.
  is grape of
  <vaem:rationale>[Pitfall Resolution Agent] Created isGrapeOf property as inverse of hasGrape: Addresses pitfall P05: missing inverse relationship for hasGrape.</vaem:rationale>
  <dc:source>(pitfall) P05</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Grape"/>
  <rdfs:range rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <owl:inverseOf rdf:resource="http://www.semanticweb.org/myontology#hasGrape"/>
</owl:ObjectProperty>

  <!-- owl:DatatypeProperty declarations -->

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasColor">
  Indicates the color of a wine, e.g., "red" or "white".
  has color
  <vaem:rationale>[Ontology Generation Agent] Created hasColor property: To answer CQ2: whether a wine is red or white.
    [Pitfall Resolution Agent] Created hasColor property: To answer CQ2: whether a wine is red or white.</vaem:rationale>
  <dc:source>(competency_question) CQ2</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBody">
  Describes the body of a wine, e.g., "light", "medium", "full".
  has body
  <vaem:rationale>[Ontology Generation Agent] Created hasBody property: To model wine body, relevant for CQ1 (wine characteristics) and CQ6 (change with vintage).
    [Pitfall Resolution Agent] Created hasBody property: To model wine body, relevant for CQ1 (wine characteristics) and CQ6 (change with vintage).</vaem:rationale>
  <dc:source>(competency_question) CQ1, CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasBouquet">
  Describes the bouquet (aroma) of a wine.
  has bouquet
  <vaem:rationale>[Ontology Generation Agent] Created hasBouquet property: To model wine bouquet, relevant for CQ1 (wine characteristics) and CQ6 (change with vintage).
    [Pitfall Resolution Agent] Created hasBouquet property: To model wine bouquet, relevant for CQ1 (wine characteristics) and CQ6 (change with vintage).</vaem:rationale>
  <dc:source>(competency_question) CQ1, CQ6</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="xsd:string"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasVintageYear">
  The vintage year of the wine.
  has vintage year
  <vaem:rationale>[Ontology Generation Agent] Created hasVintageYear property: To associate a wine with its vintage year, needed for CQ6 (change with vintage) and CQ7 (good vintages).
    [Pitfall Resolution Agent] Created hasVintageYear property: To associate a wine with its vintage year, needed for CQ6 (change with vintage) and CQ7 (good vintages).</vaem:rationale>
  <dc:source>(competency_question) CQ6, CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="xsd:gYear"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="http://www.semanticweb.org/myontology#hasRating">
  A rating for the wine, e.g., a number or quality description.
  has rating
  <vaem:rationale>[Ontology Generation Agent] Created hasRating property: To identify good vintages, as required by CQ7 (good vintages for Napa Zinfandel).
    [Pitfall Resolution Agent] Created hasRating property: To identify good vintages, as required by CQ7 (good vintages for Napa Zinfandel).</vaem:rationale>
  <dc:source>(competency_question) CQ7</dc:source>
  <rdfs:domain rdf:resource="http://www.semanticweb.org/myontology#http://www.semanticweb.org/myontology#Wine"/>
  <rdfs:range rdf:resource="xsd:string"/>
</owl:DatatypeProperty>

</rdf:RDF>