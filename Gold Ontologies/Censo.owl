  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#permitType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b13"/>
    <rdfs:comment xml:lang="es">Identifica el tipo de autorización para un vehículo. Los valores son conceptos SKOS que pertenecen a una lista controlada de tipos de autorización.</rdfs:comment>
    <rdfs:comment xml:lang="en">It identifies the type of vehicle permit. The range is a SKOS concept that belongs to a controlled list of permit types.</rdfs:comment>
    <rdfs:label xml:lang="en">permit type</rdfs:label>
    <rdfs:label xml:lang="es">tipo de autorizacion</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#licensePlateNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:comment xml:lang="en">Alphanumeric identifier assigned to a vehicle for registration and identification purposes.</rdfs:comment>
    <rdfs:comment xml:lang="es">Identificador alfanumérico asignado a un vehículo para su registro e identificación</rdfs:comment>
    <rdfs:label xml:lang="en">License Plate Number</rdfs:label>
    <rdfs:label xml:lang="es">Número de matrícula</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#beginningDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="es">Fecha de inicio del periodo de la autorización.</rdfs:comment>
    <rdfs:comment xml:lang="en">Starting date of the authorization period.</rdfs:comment>
    <rdfs:label xml:lang="es">Fecha de inicio</rdfs:label>
    <rdfs:label>Beginning Date</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://www.w3.org/2004/02/skos/core#inScheme"/>
    <owl:hasValue rdf:resource="http://vocab.linkeddata.es/datosabiertos/kos/edint/VehicleEnvironmentalBadge"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b12">
    <rdf:first rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b10"/>
