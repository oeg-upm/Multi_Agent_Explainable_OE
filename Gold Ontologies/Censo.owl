    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Owner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://schema.org/Organization"/>
    <rdfs:subClassOf rdf:resource="https://schema.org/Person"/>
    <rdfs:subClassOf rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b25"/>
    <rdfs:comment xml:lang="en">Person or organisation that is registered as the owner of a vehicle or of a vehicle permit</rdfs:comment>
    <rdfs:comment xml:lang="es">Persona u organización que está registrada como titular de un vehículo o como titular de una autorización para un vehículo</rdfs:comment>
    <rdfs:label xml:lang="en">Owner</rdfs:label>
    <rdfs:label xml:lang="es">Titular</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="en">Official permit, usually issued by the city council or the traffic authority, that allows a particular vehicle to access, drive through, or park in an area where entry is restricted or regulated</rdfs:comment>
    <rdfs:comment xml:lang="es">Permiso oficial, emitido normalmente por el ayuntamiento o la autoridad de tráfico, que habilita a un vehículo concreto a acceder, circular o estacionar en un área donde el acceso está restringido o regulado</rdfs:comment>
    <rdfs:label xml:lang="es">Autorización</rdfs:label>    
    <rdfs:label xml:lang="en">Permit</rdfs:label>

  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#propulsionType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
    <rdfs:range rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b17"/>
    <rdfs:comment xml:lang="en">Propulsion type of a vehicle. The range is a SKOS concept that belongs to a controlled list of permit types (e.g., Diesel, Petrol, Electrical, etc.).</rdfs:comment>
    <rdfs:comment xml:lang="es">Tipo de propulsión de un vehículo. Los valores son conceptos SKOS que pertenecen a una lista controlada de tipos de autorización (por ejemplo, diésel, gasolina, eléctrico, etc.)</rdfs:comment>
    <rdfs:label xml:lang="en">propulsion type</rdfs:label>
    <rdfs:label xml:lang="es">tipo de propulsión</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b16">
    <rdf:first rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b14"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://saref.etsi.org/saref4auto/Vehicle/Vehicle"/>
    <rdfs:comment xml:lang="es">Dispositivo de transporte autopropulsado, junto con cualquier accesorio, por ejemplo remolques, que es un usuario legal de la red de transporte (Fuente: ISO/TS 19091:2019(en))</rdfs:comment>
    <rdfs:comment xml:lang="en">Self-propelled transport device, along with any attachments, e.g. trailers, that is a legal user of the transportation network (Source: ISO/TS 19091:2019(en)).</rdfs:comment>
    <rdfs:label xml:lang="en">Vehicle</rdfs:label>
    <rdfs:label xml:lang="es">Vehículo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#permitStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b9"/>
    <rdfs:comment xml:lang="es">Identifica el estado de la autorización para un vehículo. Los valores son conceptos SKOS que pertenecen a una lista controlada de tipos de autorización (por ejemplo, activo, inactivo, rechazado, etc.)</rdfs:comment>
    <rdfs:comment xml:lang="en">It identifies the status of a vehicle permit. The range is a SKOS concept that belongs to a controlled list of permit types (e.g., active, inactive, rejected, etc.).</rdfs:comment>
    <rdfs:label xml:lang="es">estado de autorización</rdfs:label>
    <rdfs:label xml:lang="en">permit status</rdfs:label>
  </rdf:Description>
