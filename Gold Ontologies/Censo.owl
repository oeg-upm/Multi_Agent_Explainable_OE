  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#permitPeriodicity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b5"/>
    <rdfs:comment xml:lang="es">Identifica la periodicidad de la autorización para un vehículo. Los valores son conceptos SKOS que pertenecen a una lista controlada de tipos de autorización (por ejemplo, mensual, anual, etc.)</rdfs:comment>
    <rdfs:comment xml:lang="en">It identifies the periodicity of a vehicle permit. The range is a SKOS concept that belongs to a controlled list of permit types (e.g., monhtly, annual, etc.).</rdfs:comment>
    <rdfs:label xml:lang="es">periodicidad de la autorización</rdfs:label>
    <rdfs:label xml:lang="en">permit periodicity</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#environmentalBadge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
    <rdfs:range rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b1"/>
    <rdfs:comment xml:lang="es">Distintivo ambiental asignado a un vehículo. Los valores son conceptos SKOS que pertenecen a una lista controlada de tipos de autorización (por ejemplo, ECO, B, C, etc.)</rdfs:comment>
    <rdfs:comment xml:lang="en">Environmental badge assigned to a vehicle. The range is a SKOS concept that belongs to a controlled list of permit types (e.g., ECO, B, C, etc.).</rdfs:comment>
    <rdfs:label xml:lang="es">distintivo ambiental del vehículo</rdfs:label>
    <rdfs:label xml:lang="en">environmental badge</rdfs:label>
  </rdf:Description>
