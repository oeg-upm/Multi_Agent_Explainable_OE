  <rdf:Description rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b11">
    <rdf:first rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:rest rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b12"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos/0.1.0"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-01-29</dcterms:created>
    <dcterms:creator xml:lang="es">Daniel Doña</dcterms:creator>
    <dcterms:creator>Edna Ruckhaus</dcterms:creator>
    <dcterms:creator>Lucía Sánchez</dcterms:creator>
    <dcterms:creator>Maria del Socorro Bernardos</dcterms:creator>
    <dcterms:creator>Oscar Corcho</dcterms:creator>
    <dcterms:description xml:lang="es">El propósito de esta ontología es el de proporcionar un vocabulario común para la representación de las entidades y datos principales del censo o registro de vehículos. Su alcance se limita a los datos que pueden ser utilizados con los propósitos de cobro de impuestos por parte de las entidades locales o de gestión de la movilidad (permisos de aparcamiento, permisos de acceso a zonas específicas, etc.), que son parte de las funciones habituales de las entidades locales. Quedan fuera del alcance de la ontología otros aspectos relacionados con los vehículos, como pueden ser los datos de sus permisos de circulación, inspecciones técnicas, etc., que podrían ser objeto de una extensión de esta ontología o de su evolución en el futuro, si se considera relevante.</dcterms:description>
    <dcterms:description xml:lang="en">The purpose of this ontology is to provide a common vocabulary for representing the main entities and data of the vehicle census or registry. Its scope is limited to the data that may be used for purposes such as tax collection by local authorities or mobility management (parking permits, access permits to specific zones, etc.), which are part of the usual functions of local entities. Other aspects related to vehicles, such as data concerning driving permits, technical inspections, and similar information, are outside the scope of this ontology. These could be addressed through an extension of this ontology or through its future evolution, if considered relevant.</dcterms:description>
    <dcterms:hasFormat>http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos.owl</dcterms:hasFormat>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <vann:preferredNamespacePrefix>edintveh</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#"/>
    <owl:versionInfo>0.1.0</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#registeredOwner">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Owner"/>
    <rdfs:comment xml:lang="es">Identifica al titular (persona u organización) del vehículo</rdfs:comment>
    <rdfs:comment xml:lang="en">It identifies the person or organisation who owns the vehicle</rdfs:comment>
    <rdfs:label xml:lang="en">registered owner</rdfs:label>
    <rdfs:label xml:lang="es">titular registrado</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#activationDate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    <rdfs:comment xml:lang="es">La fecha de activación de la autorización.</rdfs:comment>
    <rdfs:comment xml:lang="en">The date on which the authorization is activated.</rdfs:comment>
    <rdfs:label xml:lang="en">Date of Activation</rdfs:label>
    <rdfs:label xml:lang="es">Fecha de activación</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/kos/edint/VehiclePermitStatus">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#authorisesVehicle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Vehicle"/>
    <rdfs:comment xml:lang="es">Identifica el vehículo al que se refiere la autorización</rdfs:comment>
    <rdfs:comment xml:lang="en">It identifies the vehicle for which the permit is issued</rdfs:comment>
    <rdfs:label xml:lang="en">authorises vehicle</rdfs:label>
    <rdfs:label xml:lang="es">autoriza vehículo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment xml:lang="es">Tramo definido por un punto de inicio y fin que puede pertenecer a una o más vías.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico"/>
    <rdfs:label xml:lang="es">Tramo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#authorisesInSegment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/transporte/censovehiculos#Permit"/>
    <rdfs:range rdf:resource="http://vocab.ciudadesabiertas.es/def/transporte/trafico#Tramo"/>
    <rdfs:comment xml:lang="es">Identifica el segmento de vía para el cual la autorización da permiso para pasar o aparcar</rdfs:comment>
    <rdfs:comment xml:lang="en">It identifies a segment where the permit authorises the vehicle to go through or park</rdfs:comment>
    <rdfs:label xml:lang="en">authorises in segment</rdfs:label>
    <rdfs:label xml:lang="es">autoriza en tramo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/kos/edint/VehiclePermitType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#NamedIndividual"/>
    <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b23">
    <rdf:first rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    <rdf:rest rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b24"/>
  </rdf:Description>
