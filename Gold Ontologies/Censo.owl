    <rdfs:comment xml:lang="en">Permit expiration date</rdfs:comment>
    <rdfs:label xml:lang="en">Ending date</rdfs:label>
    <rdfs:label xml:lang="es">Fecha de finalización</rdfs:label>
  </rdf:Description>
