    <owl:intersectionOf rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b3"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne1c67f89e8ad41d0abb669d1741be0e8b8">
